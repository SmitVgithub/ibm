# =============================================================================
# Docker Ignore File
# =============================================================================
# Excludes unnecessary files from Docker build context
# Reduces build time and image size
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github
.travis.yml
.circleci
Jenkinsfile
azure-pipelines.yml

# Docker
Dockerfile*
docker-compose*
.docker
.dockerignore

# Documentation
*.md
README*
CHANGELOG*
LICENSE*
docs/

# IDE and Editor
.idea
.vscode
*.swp
*.swo
*~
.project
.settings
*.sublime-*

# OS Files
.DS_Store
Thumbs.db
*.log

# Node.js (if any build tools)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Test files
test
tests
spec
coverage
.nyc_output
*.test.js
*.spec.js

# Build artifacts
dist
build
*.tar.gz
*.zip

# Environment files
.env
.env.*
*.local

# Temporary files
tmp
temp
*.tmp
*.temp

# Apache config (not needed in nginx container)
.htaccess
